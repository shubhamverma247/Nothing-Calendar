<resources>
    <style name="Theme.DotCal" parent="@style/Theme.DotCal.Light" />

    <style name="Theme.DotCal.Dark" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:colorAccent">#FF3B30</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:statusBarColor">#000000</item>
    </style>

    <style name="Theme.DotCal.Light" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#F7F7F7</item>
        <item name="android:colorAccent">#FF3B30</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">#FFFFFF</item>
    </style>

    <style name="WidgetPreviewWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/widget_preview_dim</item>
        <item name="android:textSize">7sp</item>
    </style>

    <style name="WidgetPreviewDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">25dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/widget_preview_primary</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="WidgetPreviewEventDay" parent="@style/WidgetPreviewDay">
        <item name="android:textColor">@color/widget_accent</item>
    </style>

    <style name="WidgetPreviewCurrentDay" parent="@style/WidgetPreviewDay">
        <item name="android:background">@drawable/widget_preview_ring_accent</item>
        <item name="android:textColor">@color/widget_accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetPreviewCalendarRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <!-- Event day: number with a small accent dot centered below it -->
    <style name="WidgetPreviewEventCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">25dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="WidgetPreviewEventDayNum">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/widget_preview_primary</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="WidgetPreviewEventDot">
        <item name="android:layout_width">3dp</item>
        <item name="android:layout_height">3dp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:src">@drawable/widget_preview_event_dot</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <!-- Today: circular ring outline that stays round inside the wide grid cell -->
    <style name="WidgetPreviewTodayCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">25dp</item>
        <item name="android:layout_weight">1</item>
    </style>
</resources>
