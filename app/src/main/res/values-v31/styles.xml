<resources>
    <style name="Theme.DotCal" parent="@style/Theme.DotCal.Dark" />

    <style name="Theme.DotCal.Dark" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:colorAccent">#FF3B30</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowSplashScreenBackground">#000000</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#000000</item>
    </style>

    <style name="Theme.DotCal.Light" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#F7F7F7</item>
        <item name="android:colorAccent">#FF3B30</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowSplashScreenBackground">#F7F7F7</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#F7F7F7</item>
    </style>
</resources>
