<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/widget_preview_ring_accent"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="27"
            android:textColor="@color/widget_preview_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="SAT"
            android:textColor="@color/widget_preview_secondary"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="1dp"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="|\n|\n|\n|\n|\n|"
        android:textColor="@color/widget_preview_secondary"
        android:textSize="7sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:text="Design Review - Q3 Roadmap"
            android:textColor="@color/widget_preview_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="10:00 · CONFERENCE R..."
            android:textColor="@color/widget_preview_secondary"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_gravity="top"
        android:background="@drawable/widget_preview_pill_accent_outline"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:text="+4"
        android:textColor="@color/widget_accent"
        android:textSize="9sp"
        android:textStyle="bold" />
</LinearLayout>
