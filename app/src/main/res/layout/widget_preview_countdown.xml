<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:padding="14dp">

    <!-- Header pinned to top -->
    <LinearLayout
        android:id="@+id/pw_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="SATURDAY"
            android:textColor="@color/widget_preview_primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:background="@drawable/widget_preview_dot_accent" />
    </LinearLayout>

    <TextView
        android:id="@+id/pw_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/pw_header_row"
        android:layout_marginTop="3dp"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:text="JUN 27"
        android:textColor="@color/widget_preview_secondary"
        android:textSize="9sp" />

    <!-- Body pinned to bottom — mirrors CSS space-between -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/widget_small_horizontal_divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Design Review"
            android:textColor="@color/widget_preview_primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="10:00 · STUDIO"
            android:textColor="@color/widget_preview_secondary"
            android:textSize="9sp" />
    </LinearLayout>

</RelativeLayout>
