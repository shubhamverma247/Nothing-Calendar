<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="16dp"
    android:paddingEnd="14dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/widget_preview_ring_accent"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="24"
            android:textColor="@color/widget_accent"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="TUE"
            android:textColor="@color/widget_preview_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="1dp"
        android:layout_height="58dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="|\n|\n|\n|"
        android:textColor="@color/widget_preview_dim"
        android:textSize="8sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:text="Quarterly Planning Sync"
            android:textColor="@color/widget_preview_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="10:00 - STUDIO"
            android:textColor="@color/widget_preview_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_preview_pill_accent_outline"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:text="+2"
        android:textColor="@color/widget_accent"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
